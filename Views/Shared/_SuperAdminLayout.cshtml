<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CEMS Super Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        Func<string, string, string> active = (c, a) =>
        {
            if (string.Equals(c, currentController, System.StringComparison.OrdinalIgnoreCase) &&
                string.Equals(a, currentAction, System.StringComparison.OrdinalIgnoreCase))
            {
                return "active";
            }
            return string.Empty;
        };

        var userName = User.Identity?.Name ?? "User";
        var initial = string.IsNullOrEmpty(userName) ? "?" : userName[0].ToString().ToUpper();
        var pageTitle = ViewData["Title"]?.ToString() ?? "Dashboard";
    }

    <!-- ══ Desktop Sidebar ══ -->
    <aside class="driver-sidebar d-none d-md-flex flex-column">
        <div class="brand p-3 d-flex align-items-center">
            <a class="d-flex align-items-center text-decoration-none" asp-controller="SuperAdmin" asp-action="Dashboard">
                <img src="@(Url.Content("~/images/logo.png"))" alt="CEMS" class="driver-logo me-2" />
            </a>
        </div>
        <nav class="nav flex-column p-3">
            <a class="nav-link driver-nav-link @(active("SuperAdmin","Dashboard"))" asp-controller="SuperAdmin" asp-action="Dashboard">
                <i class="bi bi-speedometer2"></i>
                <span>Dashboard</span>
                <i class="bi bi-check-circle nav-indicator"></i>
            </a>
            <a class="nav-link driver-nav-link @(active("SuperAdmin","Users"))" asp-controller="SuperAdmin" asp-action="Users">
                <i class="bi bi-people"></i>
                <span>User Management</span>
                <i class="bi bi-check-circle nav-indicator"></i>
            </a>
            <a class="nav-link driver-nav-link @(active("SuperAdmin","AuditLogs"))" asp-controller="SuperAdmin" asp-action="AuditLogs">
                <i class="bi bi-journal-text"></i>
                <span>Audit Logs</span>
                <i class="bi bi-check-circle nav-indicator"></i>
            </a>
        </nav>
    </aside>

    <!-- ══ Mobile Offcanvas Sidebar ══ -->
    <div class="offcanvas offcanvas-start d-md-none" tabindex="-1" id="sidebarOffcanvas" aria-labelledby="sidebarOffcanvasLabel">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title" id="sidebarOffcanvasLabel">CEMS SuperAdmin</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-0 d-flex flex-column">
            <nav class="nav flex-column p-3">
                <a class="nav-link driver-nav-link @(active("SuperAdmin","Dashboard"))" asp-controller="SuperAdmin" asp-action="Dashboard">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                    <i class="bi bi-check-circle nav-indicator"></i>
                </a>
                <a class="nav-link driver-nav-link @(active("SuperAdmin","Users"))" asp-controller="SuperAdmin" asp-action="Users">
                    <i class="bi bi-people"></i>
                    <span>User Management</span>
                    <i class="bi bi-check-circle nav-indicator"></i>
                </a>
                <a class="nav-link driver-nav-link @(active("SuperAdmin","AuditLogs"))" asp-controller="SuperAdmin" asp-action="AuditLogs">
                    <i class="bi bi-journal-text"></i>
                    <span>Audit Logs</span>
                    <i class="bi bi-check-circle nav-indicator"></i>
                </a>
            </nav>
        </div>
    </div>

    <div class="w-100">
        <main role="main" class="pb-3">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - CEMS
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
